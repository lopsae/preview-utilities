    {
      "content": [
        {
          "anchor": "discussion",
          "level": 2,
          "text": "Discussion",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The size of the button will remain consistent irregardless of the image used.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Different system images have different sizes, which can impact the size of the button. This",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "is specially noticeable when using the ",
              "type": "text"
            },
            {
              "code": ".iconOnly",
              "type": "codeVoice"
            },
            {
              "text": " label style. The label produced for the",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "button constrains the space the image can use to the space occupied by a hidden ",
              "type": "text"
            },
            {
              "inlineContent": [
                {
                  "text": "circle",
                  "type": "text"
                }
              ],
              "type": "emphasis"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "image, the displayed image itself is not resized. The image is aligned to the horizontal",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "center and first text baseline of its available space.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Large images may appear slightly closer to the label when compared to buttons using the",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "default initializers.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "This initializer creates a ",
              "type": "text"
            },
            {
              "code": "SwiftUI/Label",
              "type": "codeVoice"
            },
            {
              "text": " view on your behalf, and treats the localized key",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "similar to ",
              "type": "text"
            },
            {
              "code": "SwiftUI/Text.init(_:tableName:bundle:comment:)",
              "type": "codeVoice"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
