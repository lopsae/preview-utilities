xt":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This view was initially provided to allow a layout arrangement that can be achieved","type":"text"},{"text":" ","type":"text"},{"text":"using ","type":"text"},{"type":"codeVoice","code":".minFrameSize"},{"text":". It is left here in case further uses are found. This view may be","type":"text"},{"text":" ","type":"text"},{"text":"deleted in the future.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Content larger that the available space will overflow outside of the view while still respecting","type":"text"},{"text":" ","type":"text"},{"text":"the given alignment. Each view in the content is constrained individually, even if one view","type":"text"},{"text":" ","type":"text"},{"text":"overflows over the available space, all other views will resize themselves to the available","type":"text"},{"text":" ","type":"text"},{"text":"space.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Views in content are placed in an implicit ","type":"text"},{"type":"codeVoice","code":"ZStack"},{"text":". Providing more that one view will stack","type":"text"},{"text":" ","type":"text"},{"text":"them on top of each other, the last view provided appears at the front of the stack.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Internally, each view in content is individually constrained to a ","type":"text"},{"type":"codeVoice","code":"frame"},{"text":" sized to the available","type":"text"},{"text":" ","type":"text"},{