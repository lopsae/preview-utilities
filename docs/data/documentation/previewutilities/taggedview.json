        {
          "inlineContent": [
            {
              "text": "Used to provide a concrete-type for type-constraints in extended inits. In cases where views",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "produced by a ",
              "type": "text"
            },
            {
              "code": "ForEach",
              "type": "codeVoice"
            },
            {
              "text": " need to be tagged, this type can be used to provide a concrete type in",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "type constraints. The usual ",
              "type": "text"
            },
            {
              "code": ".tag",
              "type": "codeVoice"
            },
            {
              "text": " modifier cannot be used since it returns an opaque",
              "type": "text"
            },
