      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "Traits are passed to ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/floatingCaption(_:_:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " to build the configuration",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "of a floating caption overlay. All passed traits are applied in order to a default",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "configuration. If multiple traits that modify the same configuration properties are applied,",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "usually the last will overwrite any former.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
