{"abstract":[{"text":"View that expands to the available space and displays the given content constrained and aligned","type":"text"},{"text":" ","type":"text"},{"text":"to the available space. The view uses only the available space even when the content is larger.","type":"text"}],"identifier":{"url":"doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/previewutilities\/constrainedfill"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities"]]},"relationshipsSections":[{"identifiers":["doc:\/\/PreviewUtilities\/s8SendableP","doc:\/\/PreviewUtilities\/s16SendableMetatypeP","doc:\/\/PreviewUtilities\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ConstrainedFill","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"This view was initially provided to allow a layout arrangement that can be achieved"},{"type":"text","text":" "},{"type":"text","text":"using "},{"type":"codeVoice","code":".minFrameSize"},{"text":". It is left here in case further uses are found. This view may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"deleted in the future."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Content larger that the available space will overflow outside of the view while still respecting"},{"type":"text","text":" "},{"type":"text","text":"the given alignment. Each view in the content is constrained individually, even if one view"},{"type":"text","text":" "},{"type":"text","text":"overflows over the available space, all other views will resize themselves to the available"},{"type":"text","text":" "},{"type":"text","text":"space."}]},{"inlineContent":[{"type":"text","text":"Views in content are placed in an implicit "},{"code":"ZStack","type":"codeVoice"},{"type":"text","text":". Providing more that one view will stack"},{"text":" ","type":"text"},{"text":"them on top of each other, the last view provided appears at the front of the stack.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Internally, each view in content is individually constrained to a ","type":"text"},{"type":"codeVoice","code":"frame"},{"type":"text","text":" sized to the available"},{"text":" ","type":"text"},{"text":"space.","type":"text"}]},{"inlineContent":[{"text":"This view provides a behaviour that ","type":"text"},{"type":"codeVoice","code":".frame"},{"type":"text","text":" is unable to support: using a "},{"type":"codeVoice","code":".frame"},{"type":"text","text":" that expands"},{"type":"text","text":" "},{"type":"text","text":"to occupy all available space (with "},{"type":"codeVoice","code":".infinity"},{"type":"text","text":" for width and height) will behave the same while"},{"type":"text","text":" "},{"type":"text","text":"the content is smaller that the available space. However, if the content is larger, then the"},{"type":"text","text":" "},{"text":"size of the frame will expand to the size of the content. This view ","type":"text"},{"type":"strong","inlineContent":[{"text":"always","type":"text"}]},{"type":"text","text":" contrains the content"},{"text":" ","type":"text"},{"text":"to the available space.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill\/init(alignment:content:)"],"title":"Initializers","generated":true},{"identifiers":["doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill\/body"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill\/View-Implementations","doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill\/View-Implementations"],"title":"Default Implementations","generated":true}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Structure","externalID":"s:16PreviewUtilities15ConstrainedFillV","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ConstrainedFill","kind":"identifier"}],"modules":[{"name":"PreviewUtilities"}],"title":"ConstrainedFill","navigatorTitle":[{"kind":"identifier","text":"ConstrainedFill"}]},"sections":[],"references":{"doc://PreviewUtilities/documentation/PreviewUtilities/ConstrainedFill/body":{"type":"topic","title":"body","identifier":"doc:\/\/PreviewUtilities\/documentation\/PreviewUtilities\/ConstrainedFill\/body","url":"\/documentation\/previewutilities\/constrainedfill\/body","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"abstract":[],"kind":"symbol","role":"symbol"},"doc://PreviewUtilities/documentation/PreviewUtilities/ConstrainedFill/View-Imp