            {
              "code": "origin.x",
              "type": "codeVoice"
            },
            {
              "text": " or",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "code": "origin.y",
              "type": "codeVoice"
            },
            {
              "text": " which are updated to align to the specified edge of ",
              "type": "text"
            },
            {
