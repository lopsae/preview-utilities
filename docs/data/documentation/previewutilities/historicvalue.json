          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "Every time the displayed value changes the previous value is stored. All stored values are",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "displayed offset of the current value, towards an specified edgde.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
