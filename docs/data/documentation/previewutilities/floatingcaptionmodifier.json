    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "Displays in an overlay a floating caption text aligned to a specified ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingAlignment",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ".",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "The caption can be aligned to the center, any inner edge, and any outer edge of the parent view",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "boundaries. The overlay can be configured to display additional information like its size, and",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "to draw a border around the view’s boundary.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "All content added by this modifier is layered in an overlay of the parent view, the original",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "layout is never modified.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Apply this modifier using ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/floatingCaption(_:_:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
