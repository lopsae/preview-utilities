  "primaryContentSections": [
    {
      "declarations": [
        {
          "languages": [
            "swift"
          ],
          "platforms": [
            "macOS"
          ],
          "tokens": [
            {
              "kind": "attribute",
              "text": "@"
            },
            {
              "kind": "attribute",
              "preciseIdentifier": "s:ScM",
              "text": "MainActor"
            },
            {
              "kind": "text",
              "text": " "
            },
            {
              "kind": "keyword",
              "text": "struct"
            },
            {
              "kind": "text",
              "text": " "
            },
            {
              "kind": "identifier",
              "text": "DebugOverlayModifier"
            }
          ]
        }
      ],
      "kind": "declarations"
    },
    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "Displays in an overlay a visual representation of a view’s boundaries, its origin point, and any",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "applied safe area insets. The overlay can be configured to also display geometry information",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "like size, global origin coordinates, safe area insets, or a given text caption.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "All content added by this modifier is layered in an overlay of the parent view, the original",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "layout is never modified.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Apply this modifier using ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/debugOverlay()",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ":",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "Text(\"Sphinx of Black Quartz\")",
            "   .font(.title)",
            "Text(\"Judge my Vow\")",
            "    .font(.title)",
            "    .debugOverlay()"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "debug-overlay-default",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "anchor": "Traits-and-Configuration",
          "level": 3,
          "text": "Traits and Configuration",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The overlay can be configured by passing ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/DebugOverlayModifier/Configuration/Trait",
              "isActive": true,
              "overridingTitle": "Trait",
              "overridingTitleInlineContent": [
                {
                  "code": "Trait",
                  "type": "codeVoice"
                }
              ],
              "type": "reference"
            },
            {
              "text": " instances to",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/debugOverlay(_:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ":",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "Rectangle()",
            ".fill(.yellow.gradient)",
            ".frame(width: 200, height: 80)",
            ".debugOverlay(",
            "    .hairline,                 // sets debug borders width to 1",
            "    .width,                    // prints width of the parent view",
            "    .alignment(.innerTrailing) // aligns caption to trailing-center",
            ")"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "debug-overlay-simple-traits",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "anchor": "Visual-Components",
          "level": 3,
          "text": "Visual Components",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The boundaries of the parent view are visualized using two strokes: a dashed inner stroke (by",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "default red) drawn inset of the view’s boundaries, and a solid outer stroke (by default blue)",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "drawn outside. A cross ",
              "type": "text"
            },
            {
              "code": "+",
              "type": "codeVoice"
            },
            {
              "text": " marks the origin point, and green rectangles represent safe area",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "insets applied to the view.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "identifier": "debug-overlay-components",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "anchor": "Caption-Alignment",
          "level": 3,
          "text": "Caption Alignment",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The overlay uses ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingAlignment",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " to determine the position of the debug caption,",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "supporting positions both inside and outside of the parent view. When an ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingAlignment/OuterAlignment",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "is used, the space occupied by the parent view does not change, even if the caption is",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "displayed outside of its boundaries:",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "HStack(spacing: 16) {",
            "    Rectangle()",
            "        .fill(.green.gradient)",
            "        .frame(width: 100, height: 60)",
            "        .debugOverlay(.caption(\"Inner Top\"), .alignment(.innerTop))",
            "    Rectangle()",
            "        .fill(.mint.gradient)",
            "        .frame(width: 100, height: 60)",
            "        .debugOverlay(.caption(\"Outer Bottom\\nLeading\"), .alignment(.outerBottomLeading))",
            "    Rectangle()",
            "        .fill(.teal.gradient)",
            "        .frame(width: 100, height: 60)",
            "        .debugOverlay(.caption(\"Outer Top\\nTrailing\"), .alignment(.outerTopTrailing))",
            "}"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "debug-overlay-alignments",
              "type": "image"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
