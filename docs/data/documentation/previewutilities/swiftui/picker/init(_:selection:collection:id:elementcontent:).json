          "anchor": "discussion",
          "level": 2,
          "text": "Discussion",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "This initializer creates a ",
              "type": "text"
            },
            {
              "code": "SwiftUI/Text",
              "type": "codeVoice"
            },
            {
              "text": " view on your behalf as the picker label, using",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the given localized key.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "The views created by ",
              "type": "text"
            },
            {
              "code": "elementContent",
              "type": "codeVoice"
            },
            {
              "text": " are automatically tagged with their corresponding",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "element.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
