    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The parent content is hidden visually and for accessibility, but still occupies space normally",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "for layout purpouses.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "The parent content determines the space that will be used. The overlaid content is aligned in",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "this space. Overlaid content larger that the parent content does not modify the size occupied by",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the parent content, the overlaid content just overflows.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "This has the practical result of displaying the overlaid content aligned to the space occupied",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "by the parent view, while using exactly the size of the parent view irregardless of the size of",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the overlaid content.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
