    },
    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "An outer alignments is composed by a major component and a minor component. ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingAlignment/OuterAlignment",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "defines the major components and identifies the edge to which the content will be primarily",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "aligned: top, leading, bottom, or trailing. The minor component determines the secondary",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "direction along that edge where the content will be aligned.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Outer alignments with a vertical major (top and bottom) support three minor components: leading,",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "center, and trailing.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "identifier": "floating-alignment-outer-with-vertical-major",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Outer alignments with a horizontal major (leading and trailing) support five minor components:",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "above, top, center, bottom, and under.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "identifier": "floating-alignment-outer-with-horizontal-major",
              "type": "image"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
