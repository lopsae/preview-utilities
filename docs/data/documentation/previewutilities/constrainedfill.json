    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "content": [
            {
              "inlineContent": [
                {
                  "text": "This view was initially provided to allow a layout arrangement that can be achieved",
                  "type": "text"
                },
                {
                  "text": " ",
                  "type": "text"
                },
                {
                  "text": "using ",
                  "type": "text"
                },
                {
                  "code": ".minFrameSize",
                  "type": "codeVoice"
                },
                {
                  "text": ". It is left here in case further uses are found. This view may be",
                  "type": "text"
                },
                {
                  "text": " ",
                  "type": "text"
                },
                {
                  "text": "deleted in the future.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "name": "Note",
          "style": "note",
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "text": "Content larger that the available space will overflow outside of the view while still respecting",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the given alignment. Each view in the content is constrained individually, even if one view",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "overflows over the available space, all other views will resize themselves to the available",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "space.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Views in content are placed in an implicit ",
              "type": "text"
            },
            {
              "code": "ZStack",
              "type": "codeVoice"
            },
            {
              "text": ". Providing more that one view will stack",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "them on top of each other, the last view provided appears at the front of the stack.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Internally, each view in content is individually constrained to a ",
              "type": "text"
            },
            {
              "code": "frame",
              "type": "codeVoice"
            },
            {
              "text": " sized to the available",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "space.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "This view provides a behaviour that ",
              "type": "text"
            },
            {
              "code": ".frame",
              "type": "codeVoice"
            },
            {
              "text": " is unable to support: using a ",
              "type": "text"
            },
            {
              "code": ".frame",
              "type": "codeVoice"
            },
            {
              "text": " that expands",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "to occupy all available space (with ",
              "type": "text"
            },
            {
              "code": ".infinity",
              "type": "codeVoice"
            },
            {
              "text": " for width and height) will behave the same while",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the content is smaller that the available space. However, if the content is larger, then the",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "size of the frame will expand to the size of the content. This view ",
              "type": "text"
            },
            {
              "inlineContent": [
                {
                  "text": "always",
                  "type": "text"
                }
              ],
              "type": "strong"
            },
            {
              "text": " contrains the content",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "to the available space.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
