        },
        {
          "inlineContent": [
            {
              "text": "Convenience function for ",
              "type": "text"
            },
            {
              "code": "View.onGeometryChange(for:of:action:)",
              "type": "codeVoice"
            },
            {
              "text": " that infers the type of",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the observed value from a given ",
              "type": "text"
            },
            {
              "code": "keypath",
              "type": "codeVoice"
            },
            {
              "text": " and updates a binding directly.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "This function propagates ALL changes of the observed property to ",
              "type": "text"
            },
            {
              "code": "binding",
              "type": "codeVoice"
            },
            {
              "text": ". Use with caution.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
