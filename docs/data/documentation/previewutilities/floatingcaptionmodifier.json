    },
    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "Displays in an overlay a caption text aligned to a specified ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingAlignment",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ". The caption",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "text is configured to use its preferred size, not constrained to the size of the parent view. It",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "can be aligned to the center, any edge or corner, inside or outside, of the view’s boundaries:",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "hence it ",
              "type": "text"
            },
            {
              "inlineContent": [
                {
                  "text": "floats",
                  "type": "text"
                }
              ],
              "type": "emphasis"
            },
            {
              "text": " over the parent view attached to relative position.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "All content added by this modifier is layered in an overlay of the parent view, the original",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "layout is never modified.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Apply this modifier using ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/floatingCaption(_:_:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ", by default the caption",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "is center aligned:",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "HStack {",
            "    Rectangle()",
            "        .fill(.blue.gradient.secondary)",
            "        .frame(width: 80, height: 80)",
            "    Rectangle()",
            "        .fill(.indigo.gradient.secondary)",
            "        .frame(width: 80, height: 80)",
            "        .floatingCaption(\"A floating caption\\noverflowing the parent view\")",
            "}"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "floating-caption-default",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "anchor": "Text-and-Alignment",
          "level": 3,
          "text": "Text and Alignment",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The caption can be configured by passing ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingCaptionModifier/Trait",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " instances to ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/SwiftUICore/View/floatingCaption(_:_:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ",",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingCaptionModifier/Trait/alignment(_:)",
              "isActive": true,
              "overridingTitle": "alignment(_:)",
              "overridingTitleInlineContent": [
                {
                  "code": "alignment(_:)",
                  "type": "codeVoice"
                }
              ],
              "type": "reference"
            },
            {
              "text": " trait determines the position of the caption.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Markdown formatting is supported in the given localized string key. The caption text treats the",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "localized key similar to ",
              "type": "text"
            },
            {
              "code": "SwiftUICore/Text/init(_:tableName:bundle:comment:)",
              "type": "codeVoice"
            },
            {
              "text": ". See ",
              "type": "text"
            },
            {
              "code": "SwiftUICore/Text",
              "type": "codeVoice"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "for more information about localizing and formatting strings.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "Rectangle()",
            ".fill(.purple.gradient)",
            ".frame(width: 80, height: 80)",
            ".floatingCaption(",
            "    \"A **Purple**\\nSquare `Rectangle`\",",
            "    .alignment(.outerTrailingTop), // alignment for the caption",
            "    .height                        // prints the height of the parent view",
            ")"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "floating-caption-traits-explained",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "anchor": "Borders-and-Styles",
          "level": 3,
          "text": "Borders and Styles",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The style of the caption text can be modified with the ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingCaptionModifier/Trait/captionStyle(_:)",
              "isActive": true,
              "overridingTitle": "captionStyle(_:)",
              "overridingTitleInlineContent": [
                {
                  "code": "captionStyle(_:)",
                  "type": "codeVoice"
                }
              ],
              "type": "reference"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "trait.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Additionally an inset border can be drawn around the parent view using the ",
              "type": "text"
            },
            {
              "identifier": "doc://PreviewUtilities/documentation/PreviewUtilities/FloatingCaptionModifier/Trait/borderStyle(_:)",
              "isActive": true,
              "overridingTitle": "borderStyle(_:)",
              "overridingTitleInlineContent": [
                {
                  "code": "borderStyle(_:)",
                  "type": "codeVoice"
                }
              ],
              "type": "reference"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "trait:",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "Circle()",
            ".fill(.tertiary)",
            ".frame(width: 80, height: 80)",
            ".floatingCaption(",
            "    \"A `Circle` Shape\",",
            "    .alignment(.outerLeadingBottom),",
            "    .captionStyle(.purple),",
            "    .borderStyle(.indigo.tertiary),",
            "    .borderWidth(4)",
            ")"
          ],
          "syntax": "swift",
          "type": "codeListing"
        },
        {
          "inlineContent": [
            {
              "identifier": "floating-caption-style-and-border",
              "type": "image"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
