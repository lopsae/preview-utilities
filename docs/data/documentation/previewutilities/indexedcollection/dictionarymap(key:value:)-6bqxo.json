              "text": "The mapped keys must not produce duplicates.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Uses ",
              "type": "text"
            },
            {
              "code": "Dictionary(uniqueKeysWithValues:)",
              "type": "codeVoice"
            },
            {
              "text": " internally, which will produce a runtime error if",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "given duplicate keys.",
              "type": "text"
