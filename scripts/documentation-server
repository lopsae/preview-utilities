#!/usr/bin/python3

# Run with `python3 documentation-server`

import http.server
import socketserver
import os

PORT = 8000
PREFIX = '/preview-utilities'
DIRECTORY = 'docs' # The local folder to serve

class PrefixedHandler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        # Set the base directory for the handler (Python 3.7+)
        super().__init__(*args, directory=DIRECTORY, **kwargs)

    def translate_path(self, path):
        # Remove the prefix from the URL path before looking for the file
        if path.startswith(PREFIX):
            path = path[len(PREFIX):] or '/'
        return super().translate_path(path)

with socketserver.TCPServer(("", PORT), PrefixedHandler) as httpd:
    print(f"Serving {DIRECTORY} at http://localhost:{PORT}{PREFIX}")
    httpd.serve_forever()
