{
  "abstract": [
    {
      "text": "View that expands to the available space and displays the given content constrained and aligned",
      "type": "text"
    },
    {
      "text": " ",
      "type": "text"
    },
    {
      "text": "to the available space. The view uses only the available space even when the content is larger.",
      "type": "text"
    }
  ],
